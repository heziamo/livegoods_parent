<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itbaizhan.banner.mapper.BannerMapper">
    <resultMap id="bannerMap" type="Banner">

        <id column="id" property="id"></id>
        <result column="url" property="url"></result>
        <result column="sort" property="sort"></result>
        <result column="show" property="show"></result>
    </resultMap>

    <!-- 查询所有可见banner信息-->
    <select id="selectShowBanner" resultMap="bannerMap">
        select id,url,sort,show from lg_banner where visible=1 order by sort asc
    </select>
</mapper>
